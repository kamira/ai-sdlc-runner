[submodule "ai-skills"]
	path = ai-skills
	url = https://github.com/kamira/ai-skills.git
	# Pinned to tag ai-sdlc-v1.0.0 — NEVER track main (main drifts and breaks the contract lock). Newer tags (e.g. ai-sdlc-v1.1.0) are detected by `runner check`.
	# One-time wire-up (run by whoever provides ai-skills):
	#   git submodule add https://github.com/kamira/ai-skills.git ai-skills
	#   cd ai-skills && git checkout ai-sdlc-v1.0.0 && cd ..
	#   git add .gitmodules ai-skills && git commit -m "pin ai-skills @ ai-sdlc-v1.0.0"
	# The runner detects the actual contract version by reading the skill's
	# SKILL.md frontmatter (contract.read_skill_version), so a missing/incorrect
	# tag surfaces as a contract-version mismatch rather than silent drift.
